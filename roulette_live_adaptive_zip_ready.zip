# 1. File: roulette_live_adaptive.py

import streamlit as st
import matplotlib.pyplot as plt
import numpy as np
from collections import Counter
import time

roulette_numbers = [0,32,15,19,4,21,2,25,17,34,6,27,13,36,11,30,8,23,10,5,24,16,33,1,20,14,31,9,22,18,29,7,28,12,35,3,26]
num_positions = len(roulette_numbers)
red_numbers = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36]
black_numbers = [2,4,6,8,10,11,13,15,17,20,22,24,26,28,29,31,33,35]

def get_color(num):
    if num in red_numbers: return 'Red'
    if num in black_numbers: return 'Black'
    return 'Green'

def get_dozen(num):
    if 1 <= num <= 12: return 'Dozen 1'
    if 13 <= num <= 24: return 'Dozen 2'
    if 25 <= num <= 36: return 'Dozen 3'
    return 'Zero'

def get_low_high(num):
    if 1 <= num <= 18: return 'Low'
    if 19 <= num <= 36: return 'High'
    return 'Zero'

if 'history' not in st.session_state:
    st.session_state.history = []

avg_steps = 12
weight_decay = 0.8

def get_index(number):
    return roulette_numbers.index(number)

def update_history(number, table, area, direction, dealer_factor):
    st.session_state.history.append({
        'number': number,
        'table': table,
        'area': area,
        'color': get_color(number),
        'dozen': get_dozen(number),
        'low_high': get_low_high(number),
        'direction': direction,
        'dealer_factor': dealer_factor,
        'time': time.time()
    })

def predict_next(table, direction, dealer_factor):
    history = [h for h in st.session_state.history if h['table']==table]
    if not history:
        last_num = roulette_numbers[0]
    else:
        last_num = history[-1]['number']

    freq_nums = Counter([h['number'] for h in history[-50:]])
    freq_color = Counter([h['color'] for h in history[-50:]])
    freq_dozen = Counter([h['dozen'] for h in history[-50:]])
    freq_lowhigh = Counter([h['low_high'] for h in history[-50:]])
    max_freq = max(freq_nums.values()) if freq_nums else 1

    idx = get_index(last_num)
    probs = {}

    for i, num in enumerate(roulette_numbers):
        steps = (i - idx) % num_positions if direction=='clockwise' else (idx - i) % num_positions
        prob_distance = max(0, 1 - abs(steps - avg_steps)*(1 - weight_decay)/avg_steps)
        prob_freq = freq_nums.get(num,0)/max_freq
        prob_color = freq_color.get(get_color(num),0)/max(1,sum(freq_color.values()))
        prob_dozen = freq_dozen.get(get_dozen(num),0)/max(1,sum(freq_dozen.values()))
        prob_lowhigh = freq_lowhigh.get(get_low_high(num),0)/max(1,sum(freq_lowhigh.values()))
        probs[num] = (prob_distance*0.4 + prob_freq*0.3 + prob_color*0.1 + prob_dozen*0.1 + prob_lowhigh*0.1)*dealer_factor

    sorted_preds = sorted(probs.items(), key=lambda x: x[1], reverse=True)
    return sorted_preds[:10]

st.title('Live Roulette Predictor (Adaptive)')

with st.form('input_form'):
    num = st.number_input('Nomor keluar (0-36)', 0, 36, 0)
    table = st.selectbox('Meja',[1,2])
    area = st.selectbox('Area / Dozen / Red Black / Low High',['None','Dozen 1','Dozen 2','Dozen 3','Red','Black','Low','High'])
    direction = st.selectbox('Arah putaran',['clockwise','counterclockwise'])
    dealer_factor = st.slider('Faktor dealer',0.8,1.2,1.0)
    submitted = st.form_submit_button('Tambah Putaran')
    if submitted:
        update_history(num,table, area if area!='None' else None, direction, dealer_factor)

st.subheader('Histori Putaran')
if st.session_state.history:
    for h in st.session_state.history:
        st.write(f"{h['number']} - Meja {h['table']} - {h['area']} - Color {h['color']} - {h['dozen']} - {h['low_high']}")
else:
    st.write('Belum ada histori.')

st.subheader('Prediksi Top 10')
pred_table = st.selectbox('Prediksi untuk meja:',[1,2])
predictions = predict_next(pred_table, direction, dealer_factor)
for num,score in predictions:
    st.write(f"{num} ({get_color(num)}, {get_dozen(num)}, {get_low_high(num)}) -> {score:.2f}")

fig,ax = plt.subplots(figsize=(6,6),subplot_kw={'polar':True})
angles = np.linspace(0,2*np.pi,num_positions,endpoint=False)
for i,n in enumerate(roulette_numbers):
    ax.text(angles[i],1.0,str(n),fontsize=9,ha='center',va='center')
if st.session_state.history:
    lastnum = st.session_state.history[-1]['number']
    ax.plot([angles[get_index(lastnum)]],[1.0],'ro',markersize=12,label='Last')
for n,_ in predictions:
    idx = get_index(n)
    ax.plot([angles[idx]],[1.0],'go',markersize=9,alpha=0.6)
ax.set_yticklabels([])
ax.set_xticklabels([])
ax.legend(['Last Number','Top 10'])
st.pyplot(fig)

-- FILE END --

